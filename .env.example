#############################################
# PamaPay Environment Variables
# Copy this file to .env or configure these
# values as operating system environment variables.
#############################################

#########################
# JWT Configuration
#########################

JWT_SECRET=replace-with-a-secure-random-secret-key
JWT_EXPIRATION=3600000

#########################
# Database Configuration
#########################

DB_HOST=localhost
DB_PORT=5432
DB_NAME=pamapay
DB_USERNAME=pamapay_user
DB_PASSWORD=replace-with-your-database-password

#########################
# Spring Profile
#########################

SPRING_PROFILES_ACTIVE=dev